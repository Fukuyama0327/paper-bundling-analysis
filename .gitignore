.DS_Store
Thumbs.db

# Python
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/

# Jupyter
.ipynb_checkpoints/

# Data and generated artifacts
cache/
outputs/**
!outputs/README.md
data/raw/
data/external/
data/interim/

# Reference PDFs are managed locally; keep metadata and notes in Git instead.
references/pdf/*.pdf
references/pdf/**/*.pdf

# Reference source materials (Office binaries at references/ root) are kept locally.
# Already-tracked ones (e.g. area_management_survey_report*.docx) stay in Git;
# these patterns only stop new large docx/pptx source files from being committed.
references/*.docx
references/*.pptx

# Office temporary files
~$*
*.tmp

# Districting atlas vector exports are heavy (SVG ~1M lines, PDF ~9MB) and
# regenerable from the committed solutions pkl via scripts/make_districting_maps.py.
# Keep only the PNG in Git.
figures/atlas/*.svg
figures/atlas/*.pdf

# LaTeX build artifacts (regenerate via lualatex/latexmk; source .tex/.sty/.cls are tracked)
# main.pdf is excluded too since it's regenerable from main.tex; `git add -f paper/latex/main.pdf`
# if you'd rather keep a viewable copy on GitHub.
paper/latex/*.aux
paper/latex/*.log
paper/latex/*.out
paper/latex/*.synctex.gz
paper/latex/*.toc
paper/latex/*.bbl
paper/latex/*.blg
paper/latex/*.fls
paper/latex/*.fdb_latexmk
paper/latex/main.pdf
paper/latex/.overleaf/

# Local settings
.env
.claude/settings.local.json
.obsidian/

# Local license files
gurobi.lic
.gurobi/

# Local scratch and tool cruft (not part of the project)
.trash_local/
tmp/
AGENTS.md
